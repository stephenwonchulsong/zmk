docker cp zealous_pasteur:/workspaces/zmk/app/build/369ulp_r/zephyr/zmk.uf2 "/Users/song100/Library/Mobile Documents/com~apple~CloudDocs/Keyboard/36firmware/369ulp_right.uf2"
docker cp zealous_pasteur:/workspaces/zmk/app/build/369ulp_tp/zephyr/zmk.uf2 "/Users/song100/Library/Mobile Documents/com~apple~CloudDocs/Keyboard/36firmware/369ulp_tp.uf2"

