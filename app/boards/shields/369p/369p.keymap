 west build -d build/369p_right -p -b xiao_ble//zmk -- -DSHIELD=369p_right
 west build -d build/xiao_ble_reset -p -b xiao_ble//zmk -- -DSHIELD=settings_reset
 *
 docker cp naughty_cohen:/workspaces/zmk/app/build/369p_left/zephyr/zmk.uf2 "/Users/song100/Library/Mobile Documents/com~apple~CloudDocs/Keyboard/36firmware/369p_left.uf2"
 docker cp naughty_cohen:/workspaces/zmk/app/build/369p_right/zephyr/zmk.uf2 "/Users/song100/Library/Mobile Documents/com~apple~CloudDocs/Keyboard/36firmware/369p_right.uf2"
 docker cp naughty_cohen:/workspaces/zmk/app/build/xiao_ble_reset/zephyr/zmk.uf2 "/Users/song100/Library/Mobile Documents/com~apple~CloudDocs/Keyboard/36firmware/xiao_ble_reset.uf2"
 *
